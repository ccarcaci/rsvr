# Dockerfile.whap — WhatsApp Mock Server for Local Development
#
# Source: https://github.com/ccarcaci/whap
# Whap emulates the WhatsApp Cloud API endpoints locally so rsvr can send and
# receive WhatsApp messages without a real Meta Business account.
#
# This image includes full source code and Bun runtime for development and
# debugging via the Bun Inspector (port 9229).
#
# Build:
#   docker build -f local_infra/Dockerfile_whap --tag whap:debug .
#
# Run with debugging:
#   docker run -it -p 3010:3010 -p 9229:9229 whap:debug \
#     bun --inspect-brk src/index.ts server
#
# Then connect your IDE debugger to localhost:9229 (VSCode, WebStorm, etc.)
# or use Bun's built-in debugger at chrome://inspect

FROM oven/bun:1.2-debian

WORKDIR /app

# Install git and ca-certificates for cloning from GitHub and HTTPS calls.
RUN apt-get update \
    && apt-get install --reinstall --yes ca-certificates \
    && apt-get install --yes --no-install-recommends git curl \
    && rm --recursive --force /var/lib/apt/lists/*

# Clone whap at a pinned ref (branch/tag/commit) for reproducible builds.
# Change this to update: docker build --build-arg WHAP_REF=v1.2.3 ...
ARG WHAP_REF=main
RUN git clone --depth 1 --branch "${WHAP_REF}" \
        https://github.com/ccarcaci/whap.git .

# Install dependencies with frozen lockfile (prevents silent drift).
RUN bun install --frozen-lockfile

# Security: run as non-root user (UID/GID 1001).
RUN groupadd --gid 1001 whap \
    && useradd --uid 1001 --gid whap --no-create-home --shell /usr/sbin/nologin whap

# Expose ports: 3010 for server, 9229 for Bun Inspector debugger.
EXPOSE 3010 9229

# Health check: /health endpoint should return 200 when ready.
HEALTHCHECK --interval=10s --timeout=5s --start-period=15s --retries=3 \
    CMD curl --fail --silent http://localhost:3010/health || exit 1

USER whap

# Default: run the server. Override for debugging:
#   bun --inspect-brk src/index.ts server
# Or for other tasks:
#   bun run test
#   bunx biome check src/
ENTRYPOINT ["bun"]
CMD ["src/index.ts", "server"]
